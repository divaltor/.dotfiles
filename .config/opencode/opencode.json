{
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
  },
  "permission": "allow",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    }
  },
  "experimental": {
    "openTelemetry": true
  },
  "references": {
    "opencode": {
      "path": "anomalyco/opencode",
      "description": "Official repo of Opencode"
    }
  },
  "default_agent": "morney",
  "$schema": "https://opencode.ai/config.json"
}
