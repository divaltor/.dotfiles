{
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/$HOME/dev/**": "allow"
    }
  },
  "mcp": {
    "parallel-ai": {
      "type": "remote",
      "url": "https://search-mcp.parallel.ai/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:PARALLEL_API_KEY}"
      }
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    }
  },
  "experimental": {
    "openTelemetry": true
  },
  "default_agent": "morney",
  "$schema": "https://opencode.ai/config.json"
}
