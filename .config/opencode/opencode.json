{
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
  },
  "permission": "allow",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
  },
  "experimental": {
    "openTelemetry": true
  },
  "default_agent": "morney",
  "$schema": "https://opencode.ai/config.json"
}
