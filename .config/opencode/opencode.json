{
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    }
  },
  "lsp": true,
  "formatter": true,
  "permission": "allow",
  "mcp": {
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "experimental": {
    "openTelemetry": true
  },
  "references": {
    "opencode": {
      "repository": "anomalyco/opencode",
      "description": "Official repo of Opencode"
    }
  },
  "default_agent": "diana",
  "disabled_providers": [
    "amazon-bedrock"
  ],
  "$schema": "https://opencode.ai/config.json"
}
