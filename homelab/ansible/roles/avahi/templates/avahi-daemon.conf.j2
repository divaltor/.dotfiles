# Avahi daemon configuration
# Generated by Ansible — do not edit manually

[server]
host-name={{ avahi_hostname }}
use-ipv4=yes
use-ipv6=no
allow-interfaces={{ avahi_allow_interfaces }}
deny-interfaces=

[publish]
publish-addresses=yes
publish-hinfo=yes
publish-workstation={{ avahi_publish_workstation | lower }}
publish-domain=yes

[reflector]
enable-reflector={{ avahi_reflector | lower }}

[rlimits]
rlimit-core=0
rlimit-data=4194304
rlimit-fsize=0
rlimit-nofile=768
rlimit-stack=4194304
rlimit-nproc=3
